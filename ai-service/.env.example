APP_NAME=yetbota-ai-service
APP_VERSION=0.1.0
REST_HOST=0.0.0.0
# Use a port other than Weaviate HTTP (8080) when running local docker-compose Weaviate.
REST_PORT=8001
GRPC_HOST=0.0.0.0
GRPC_PORT=9090

# Comma-separated list; examples: "localhost,127.0.0.1,mydomain.com"
CORS_HOSTS=localhost,127.0.0.1

# Phase 2+
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

WEAVIATE_URL=
WEAVIATE_API_KEY=
WEAVIATE_COLLECTION=

# Optional overrides (normally you only need WEAVIATE_URL)
WEAVIATE_HTTP_PORT=
WEAVIATE_SECURE=
# Repo root docker-compose maps host gRPC to 50052 (container 50051).
WEAVIATE_GRPC_PORT=50052

WEAVIATE_VECTOR_NAME=default
WEAVIATE_VERIFIED_PROPERTY=verified

RAG_TOP_K=8
RAG_MIN_SCORE=

